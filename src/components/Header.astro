---
import logo from "../assets/image/movil.webp";
import artits from "../assets/image/Gallery8.webp";
import img from "../assets/image/video1.webp";
import Img2 from "../assets/image/Ep.jpg";
import img3 from "../assets/image/partner.png";
---
<header class="content-block" id="home">
  <img class="content-img" src={logo.src} alt="">
  <div class="content-box"> 
  </div>
</header>

<section class="intro">
  <div>
    <h2>Juan de Mata<span> Sounds of My Life</span></h2>
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Nostrum enim
      accusantium voluptatibus dicta inventore sunt aperiam, quae minima reiciendis temporibus?
    </p>
  </div>
  <img src={artits.src} alt="Artist Image">
</section>

<figure class="img-frame">
  <h2>CHECK OUT MY LATEST VIDEO</h2>
  <a href="https://www.youtube.com/watch?v=APvMlSJu6Tc&list=RDAPvMlSJu6Tc&start_radio=1" target="_blank" rel="noopener noreferrer">
    <img src={img.src} alt="video1">
    <p>cantante de la calle - Juan de mata</p>
  </a>
</figure>

<section class="release-container">
  
  <div class="image-col">
    <img src={Img2.src} alt="Aurora Echoes Album Cover" class="album-cover">
  </div>

  <div class="content-col">
    <span class="eyebrow">LATEST RELEASE</span>
    <h2>RESONANCE</h2>
    
    <p class="description">
      The definitive sound of the year. Featuring the hit single "Cantante de la calle" 
      RESONANCE is a journey through high-fidelity basslines and melodic 
      precision. Experience the album that is topping the charts worldwide.
    </p>

    <h3 class="platforms-title">LISTEN ON ALL PLATFORMS</h3>
    
    <div class="platforms-grid">
      <a href="https://open.spotify.com/intl-es/artist/6i0yREPZXoqnAKGISSI8Cc?si=Qbn4vhhJQrCOlnyEeQCekg" class="platform-btn" target="_blank" rel="noopener noreferrer">
        <span class="icon spotify"></span> Spotify
      </a>
      <a href="https://music.apple.com/us/artist/juan-de-mata/6772744395?l=es-MX" class="platform-btn" target="_blank" rel="noopener noreferrer">
        <span class="icon apple"></span> Apple
      </a>
      <a href="https://www.deezer.com/es/artist/115135242" class="platform-btn" target="_blank" rel="noopener noreferrer">
        <span class="icon deezer">ılı</span> Deezer
      </a>
      <a href="https://www.qobuz.com/ie-en/album/musica-del-alma-juan-de-mata/uwtvna6qizaub#" class="platform-btn" target="_blank" rel="noopener noreferrer">
        <span class="icon qobuz">Q</span> Qobuz
      </a>
      <a href="https://www.youtube.com/channel/UCCdLE5D7-6wHgIpb_eMzdiw/" class="platform-btn" target="_blank" rel="noopener noreferrer">
        <span class="icon youtube">▶</span> YouTube
      </a>
    </div>
  </div>
</section>

<section class="partners-section">
  <span class="eyebrow">PARTNERS & PRODUCTION</span>
  <h2 class="title">BACKED BY</h2>
  <p>RAGGART RECORDS</p>
  
  <div class="partners-container">
    <div class="partner-card">
      <a href="https://djraggart.com/" target="_blank" rel="noopener noreferrer"><img src={img3.src} alt="Partner Logo" class="partner-logo"></a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../assets/sass/index' as *;

  header {
    display: flex;
    justify-content: center;
    align-items: center;
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
    width: 100%;
  }
  img {
    width: 100%;
  }

  .content-box {
    display: flex;
    justify-content: left;
    text-align: left; 
  }
  //section 2
    .intro {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 60px;
      background-color: #0a0a0a;

      img{
        width: 100%;
        max-width: 750px;
        height: auto;
      }

      h2 {
        margin-top: 50px;
      }

      span {
        color: $yellow;
      }
    }
  //end

figure {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background-color: black;
  padding: 80px 0px;
  margin: 0;

  h2 {
    font-size: 1.5rem;
    color: $white;
    margin: 50px 0;
  }

  a {
    text-decoration: none;
    color: $white;

    img {
      width: 100%;
      max-width: 600px;
      height: auto;
      border-radius: 8px;  
      
      /* Animamos tanto el tamaño como el brillo */
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      
      /* Brillo base combinando ambos colores */
      /* Sombra verde a la izquierda/arriba, sombra amarilla a la derecha/abajo */
      box-shadow: 
        -8px -8px 20px -5px #026B41, 
         8px  8px 20px -5px #FAB821;

      &:hover {
        transform: scale(1.05);
        /* Al hacer hover, el brillo se expande y se hace más intenso */
        box-shadow: 
          -12px -12px 30px -5px #026B41, 
           12px  12px 30px -5px #FAB821;
      }
    }

    p {
      margin: 30px 0;
      font-size: 0.75rem;
      color: $white;
    }
  }
}

  // new

  .release-container {
    background-color: #0a0a0a;
    padding: 40px 20px;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: #ffffff;
    
    /* Comportamiento por defecto (Móvil): Apilado */
    display: flex;
    flex-direction: column;
    gap: 40px;
    box-sizing: border-box;
    margin: 0; 

  /* Estilos de la imagen */
  .image-col {
    width: 100%;
    max-width: 450px;
    margin: 0 auto; /* Centrado en móvil */
    
    .album-cover {
      width: 100%;
      height: auto;
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6); /* Sombra para darle profundidad */
      display: block;
    }
  }

  /* --- INICIO DE ESTILOS DESKTOP --- */
  @media (min-width: 768px) {
    flex-direction: row; /* Coloca imagen y texto lado a lado */
    align-items: center; /* Centra ambos verticalmente */
    gap: 60px; /* Espacio grande entre la imagen y el texto */
    padding: 80px 40px;

    .image-col {
      flex: 0 0 45%; /* La imagen toma el 45% del ancho */
      margin: 0;
    }

    .content-col {
      flex: 1; /* El texto ocupa el espacio restante */
    }

    /* Ajustes sutiles de tipografía para pantallas grandes */
    h2 {
      font-size: 3rem; /* Título más grande en PC */
    }
    
    .description {
      font-size: 1.05rem;
    }
  }
  /* --- FIN DE ESTILOS DESKTOP --- */

  /* Estilos internos (Texto y Botones) - Se aplican a todos los tamaños */
  .content-col {
    .eyebrow {
      color: #f39c12;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 8px;
      display: block;
    }

    h2 {
      font-size: 2.2rem; /* Tamaño base móvil, se sobrescribe en el media query */
      margin: 0 0 15px 0;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    .description {
      color: #a3a3a3;
      font-size: 0.95rem;
      line-height: 1.6;
      margin: 0 0 35px 0;
    }

    .platforms-title {
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 15px;
      margin-left: 0;
    }

    .platforms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); 
      gap: 12px;

      .platform-btn {
        background-color: #161616;
        border: 1px solid #262626;
        border-radius: 10px;
        padding: 14px 16px;
        color: #ffffff;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: background-color 0.3s ease, transform 0.2s ease;

        &:hover {
          background-color: #222222;
          transform: translateY(-2px);
        }

        .icon {
          font-size: 1.2rem;
          display: flex;
          align-items: center;
          justify-content: center;
          width: 24px;
          height: 24px;
          
          &.spotify { background-color: #1DB954; border-radius: 50%; }
          &.apple { color: #ffffff; }
          &.deezer { font-weight: bold; font-size: 1rem; }
          &.qobuz { font-weight: 800; font-family: sans-serif; color: #ffffff; }
          &.youtube { color: #FF0000; font-size: 1.1rem; }
        }
      }
    }
  }
}


/* Variables de color basadas en la imagen */
$bg-dark: #111111;
$card-bg: #161616;
$card-border: #262626;
$text-green: #88dca8; /* Verde menta pálido */
$text-white: #ffffff;

.partners-section {
  background-color: $bg-dark;
  padding: 80px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  text-align: center;
  box-sizing: border-box;

  p {
    font-size: 1rem;
    color: $text-white;
    font-weight: 500;
    font-family: Nulshock, sans-serif;
  }

  .eyebrow {
    color: $text-green;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-family: Nulshock, sans-serif;
  }

  .title {
    color: $text-white;
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 40px 0;
    text-transform: uppercase;
    letter-spacing: -1px;
    /* Efecto de sombra sutil para darle profundidad como en la imagen */
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
    font-family: Nulshock, sans-serif;
  }

  .partners-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    
    .partner-card {
      background-color: $card-bg;
      border: 1px solid $card-border;
      border-radius: 16px;
      width: 260px;
      height: 260px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      /* Sombra interior y exterior muy sutiles */
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.02);

      &:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.05);
      }

      .partner-logo {
        width: 100%; /* Ajusta este tamaño según las proporciones de tu logo real */
        height: auto;
        opacity: 0.7; /* El logo en la imagen tiene un tono grisáceo/opaco */
        transition: opacity 0.3s ease;
        /* Si tu logo es negro y necesitas que se vea gris/blanco, puedes usar: filter: invert(1) opacity(0.7); */

        &:hover {
          opacity: 1; /* Se ilumina al pasar el mouse */
        }
      }
    }
  }
}

  @media only screen and (min-width: 1024px) {

    .content-block {
      background-image: url("../assets/image/desktop.webp");
      background-repeat: no-repeat;
      background-position: center;
      overflow: hidden;
      width: 100%;
      height: 80vh;
    }

    .content-img {
      display: none;
    }

    .intro {
      flex-direction:row-reverse;
      justify-content: space-between;
      padding: 100px 80px;
       justify-content: left;
      align-items: left;
    }

    .intro h2 {
    font-size: 3rem;
    margin-top: 0;
    }

    .intro p {
      font-size: 1.2rem;
      padding: 50px 0
    } 

    figure {
      alin-items: center;

    }
  }
</style>
